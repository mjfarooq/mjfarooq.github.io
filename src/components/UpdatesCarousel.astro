---
import all from "../data/updates.json";
import site from "../data/site.json";
const isPub = (u) => u.category === "publication";
const sections = [
  { title: "Activities", items: all.filter((u) => !isPub(u)).slice(0, 12) },
  { title: "Publications", items: all.filter(isPub).slice(0, 12) },
];
const linkMembers = (site.group.members || []).filter((m) => m.profile);
const linkify = (t) => {
  let s = t;
  for (const m of linkMembers) s = s.split(m.name).join(`<a class="uc-namelink" href="${m.profile}">${m.name}</a>`);
  return s;
};
---
<div class="uc-wrap" id="updates">
  <div class="uc-top">
    <span class="eyebrow">Recent updates</span>
    <h2 class="h-sec">News from the lab</h2>
  </div>
  {sections.map((sec) => sec.items.length > 0 && (
    <div class="uc">
      <div class="uc-head">
        <h2 class="uc-title">{sec.title}</h2>
        <div class="uc-nav">
          <button class="uc-btn" data-dir="-1" aria-label="Previous">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="uc-btn" data-dir="1" aria-label="Next">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
      <div class="uc-row">
        {sec.items.map((u) => (
          <article class="uc-card" data-date={u.date} data-message={linkify(u.message)} data-images={JSON.stringify(u.images || [])} data-link={u.link || ""}>
            {u.images && u.images.length > 0 && (
              <div class={"uc-photos n" + Math.min(u.images.length, 3)}>
                {u.images.slice(0, 3).map((img, i) => (
                  <div class="uc-photo">
                    <img src={img} style={`object-position:${(u.imgPos && u.imgPos[i]) || 'center'}`} data-gallery={JSON.stringify(u.images)} data-index={i} alt="" loading="lazy" onerror="this.closest('.uc-photo').style.display='none'" />
                    {i === 2 && u.images.length > 3 && <span class="uc-more" data-gallery={JSON.stringify(u.images)} data-index={i}>+{u.images.length - 3}</span>}
                  </div>
                ))}
              </div>
            )}
            <div class="uc-body">
              <span class="uc-date">{u.date}</span>
              <p class="uc-msg" set:html={linkify(u.message)}></p>
              <button type="button" class="uc-link uc-expand">Read more →</button>
            </div>
          </article>
        ))}
      </div>
    </div>
  ))}
</div>

<div class="uc-modal" id="uc-modal" aria-hidden="true">
  <div class="uc-modal-overlay" data-close></div>
  <div class="uc-modal-panel">
    <button class="uc-modal-close" type="button" data-close aria-label="Close">×</button>
    <div class="uc-modal-content">
      <span class="uc-modal-date"></span>
      <div class="uc-modal-images"></div>
      <p class="uc-modal-msg"></p>
      <a class="uc-modal-link" target="_blank" rel="noopener" hidden>Visit source →</a>
    </div>
  </div>
</div>

<style>
  .uc-wrap { display: flex; flex-direction: column; gap: 1.4rem; }
  .uc-head { display: flex; justify-content: space-between; align-items: center; gap: 1rem; margin-bottom: .7rem; }
  .uc-title { font-family: var(--ff-serif); font-size: 1.15rem; font-weight: 600; color: var(--blue); margin: 0; }
  :root[data-theme="dark"] .uc-title { color: var(--text); }
  .uc-nav { display: flex; gap: .5rem; }
  .uc-btn { width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--border-strong); background: var(--surface); color: var(--blue); cursor: pointer; display: grid; place-items: center; transition: all .18s; }
  :root[data-theme="dark"] .uc-btn { color: var(--text); }
  .uc-btn:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

  /* native horizontal scroll, identical to the student-page "In the news" strip */
  .uc-row { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; overscroll-behavior-x: contain; -webkit-overflow-scrolling: touch; scrollbar-width: none; padding-bottom: 2px; }
  .uc-row::-webkit-scrollbar { display: none; }
  .uc-card { flex: 0 0 264px; height: 380px; scroll-snap-align: start; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; }

  .uc-photos { display: grid; gap: 2px; height: 170px; flex: 0 0 170px; }
  .uc-photos.n1 { grid-template-columns: 1fr; }
  .uc-photos.n2 { grid-template-columns: 1fr 1fr; }
  .uc-photos.n3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; }
  .uc-photos.n3 .uc-photo:first-child { grid-row: 1 / 3; }
  .uc-photo { position: relative; overflow: hidden; background-color: var(--blue); }
  .uc-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; cursor: zoom-in; }
  /* single-image cards show the whole figure inside the fixed box (scaled, not cropped) */
  .uc-photos.n1 .uc-photo { background: var(--surface-soft); }
  .uc-photos.n1 .uc-photo img { object-fit: contain; }
  .uc-more { position: absolute; inset: 0; background: rgba(0,39,76,.62); color: #fff; font-family: var(--ff-mono); font-size: 15px; display: flex; align-items: center; justify-content: center; cursor: zoom-in; }

  .uc-body { padding: .85rem 1rem 1rem; display: flex; flex-direction: column; flex: 1; }
  .uc-date { font-family: var(--ff-mono); font-size: 11px; letter-spacing: .04em; color: var(--blue-link); background: var(--surface-soft); border: 1px solid var(--border); padding: .15rem .5rem; border-radius: 5px; align-self: flex-start; margin-bottom: .55rem; }
  .uc-msg { font-size: 13.5px; color: var(--text); line-height: 1.5; margin: 0 0 .6rem; display: -webkit-box; -webkit-line-clamp: 5; line-clamp: 5; -webkit-box-orient: vertical; overflow: hidden; }
  .uc-msg :global(.uc-namelink) { color: var(--blue-link); font-weight: 600; }
  .uc-expand { background: none; border: 0; padding: 0; cursor: pointer; font-family: var(--ff-mono); font-size: 12px; color: var(--blue-link); margin-top: auto; text-align: left; }
  .uc-expand:hover { text-decoration: underline; }

  .uc-modal { display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; padding: 24px; }
  .uc-modal.open { display: flex; }
  .uc-modal-overlay { position: absolute; inset: 0; background: rgba(8,18,34,.7); cursor: zoom-out; }
  .uc-modal-panel { position: relative; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; max-width: 720px; width: 100%; max-height: 88vh; overflow-y: auto; padding: 2rem; box-shadow: 0 24px 70px rgba(0,0,0,.45); }
  .uc-modal-close { position: absolute; top: 12px; right: 12px; width: 36px; height: 36px; border-radius: 50%; border: 1px solid var(--border-strong); background: var(--surface); color: var(--text); font-size: 22px; line-height: 1; cursor: pointer; display: grid; place-items: center; padding: 0; }
  .uc-modal-close:hover { background: var(--bg-soft); }
  .uc-modal-date { font-family: var(--ff-mono); font-size: 12px; letter-spacing: .04em; color: var(--blue-link); background: var(--surface-soft); border: 1px solid var(--border); padding: .2rem .55rem; border-radius: 5px; display: inline-block; }
  .uc-modal-images { display: flex; flex-direction: column; gap: 12px; margin: 1.1rem 0 1rem; }
  .uc-modal-images img { width: 100%; height: auto; max-height: 520px; object-fit: contain; border-radius: 8px; background: var(--surface-soft); cursor: zoom-in; }
  .uc-modal-msg { font-size: 1.02rem; line-height: 1.65; color: var(--text); margin: 0 0 1rem; }
  .uc-modal-msg :global(.uc-namelink) { color: var(--blue-link); font-weight: 600; }
  .uc-modal-link { font-family: var(--ff-mono); font-size: 13px; color: var(--blue-link); }
  .uc-link { font-family: var(--ff-mono); font-size: 12px; margin-top: auto; }
</style>

<script is:inline>
  (function(){
    document.querySelectorAll(".uc-wrap .uc").forEach(function(uc){
      var row = uc.querySelector(".uc-row");
      if(!row) return;
      function step(){ var c = row.querySelector(".uc-card"); return c ? c.offsetWidth + 16 : 280; }
      uc.querySelectorAll(".uc-btn").forEach(function(b){
        b.addEventListener("click", function(){ row.scrollBy({ left: parseInt(b.getAttribute("data-dir"),10) * step(), behavior: "smooth" }); });
      });
    });

    var modal = document.getElementById("uc-modal");
    if(modal){
      var msgEl = modal.querySelector(".uc-modal-msg");
      var dateEl = modal.querySelector(".uc-modal-date");
      var imgsEl = modal.querySelector(".uc-modal-images");
      var linkEl = modal.querySelector(".uc-modal-link");
      function openModal(card){
        dateEl.textContent = card.getAttribute("data-date") || "";
        msgEl.innerHTML = card.getAttribute("data-message") || "";
        imgsEl.innerHTML = "";
        try{
          var imgs = JSON.parse(card.getAttribute("data-images") || "[]");
          imgs.forEach(function(src){
            var img = document.createElement("img");
            img.src = src; img.alt = "";
            img.setAttribute("data-gallery", JSON.stringify(imgs));
            img.setAttribute("data-index", String(imgs.indexOf(src)));
            img.onerror = function(){ img.style.display = "none"; };
            imgsEl.appendChild(img);
          });
        }catch(e){}
        var link = card.getAttribute("data-link") || "";
        if(link){ linkEl.href = link; linkEl.hidden = false; } else { linkEl.hidden = true; }
        modal.classList.add("open");
        modal.setAttribute("aria-hidden","false");
        document.body.style.overflow = "hidden";
      }
      function closeModal(){
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden","true");
        msgEl.innerHTML = ""; imgsEl.innerHTML = "";
        document.body.style.overflow = "";
      }
      document.addEventListener("click", function(e){
        var btn = e.target.closest(".uc-expand");
        if(btn){ openModal(btn.closest(".uc-card")); return; }
        if(e.target.closest("#uc-modal [data-close]")){ closeModal(); }
      });
      document.addEventListener("keydown", function(e){ if(e.key === "Escape" && modal.classList.contains("open")) closeModal(); });
    }
  })();
</script>
