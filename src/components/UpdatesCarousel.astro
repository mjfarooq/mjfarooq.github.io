---
import all from "../data/updates.json";
import site from "../data/site.json";
const isPub = (u) => u.category === "publication";
const newsItems = all.filter((u) => !isPub(u)).slice(0, 12).map((u) => ({ u, cat: "news" }));
const pubItems = all.filter(isPub).slice(0, 12).map((u) => ({ u, cat: "publication" }));
const items = newsItems.concat(pubItems);
const linkMembers = (site.group.members || []).filter((m) => m.profile);
const linkify = (t) => {
  let s = t;
  for (const m of linkMembers) s = s.split(m.name).join(`<a class="uc-namelink" href="${m.profile}">${m.name}</a>`);
  return s;
};
---
<div class="uc" id="updates">
  <div class="uc-head">
    <div>
      <span class="eyebrow">Recent updates</span>
      <h2 class="h-sec">News from the lab</h2>
      <div class="uc-tabs" role="tablist">
        <button class="uc-tab on" data-cat="news">News</button>
        <button class="uc-tab" data-cat="publication">Publications</button>
      </div>
    </div>
    <div class="uc-nav">
      <button class="uc-btn" data-dir="-1" aria-label="Previous">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="uc-btn" data-dir="1" aria-label="Next">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div class="uc-window">
    {items.map(({ u, cat }) => (
      <article class="uc-card" data-cat={cat} style={cat === "publication" ? "display:none" : undefined}>
        {u.images && u.images.length > 0 && (
          <div class={"uc-photos n" + Math.min(u.images.length, 3)}>
            {u.images.slice(0, 3).map((img, i) => (
              <div class="uc-photo">
                <img src={img} style={`object-position:${(u.imgPos && u.imgPos[i]) || 'center'}`} data-gallery={JSON.stringify(u.images)} data-index={i} alt="" loading="lazy" onerror="this.closest('.uc-photo').style.display='none'" />
                {i === 2 && u.images.length > 3 && <span class="uc-more" data-gallery={JSON.stringify(u.images)} data-index={i}>+{u.images.length - 3}</span>}
              </div>
            ))}
          </div>
        )}
        <div class="uc-body">
          <span class="uc-date">{u.date}</span>
          <p class="uc-msg" set:html={linkify(u.message)}></p>
          {u.link && <a class="uc-link" href={u.link} target="_blank" rel="noopener">View post →</a>}
        </div>
      </article>
    ))}
  </div>
  <div class="uc-dots"></div>
</div>

<style>
  .uc { margin-top: .5rem; }
  .uc-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; margin-bottom: 1.2rem; }
  .uc-tabs { display: flex; gap: .4rem; margin-top: .8rem; }
  .uc-tab { font-family: var(--ff-mono); font-size: 12px; padding: .38rem .8rem; border-radius: 7px; background: var(--surface); border: 1px solid var(--border); color: var(--text-soft); cursor: pointer; }
  .uc-tab:hover { border-color: var(--border-strong); }
  .uc-tab.on { background: var(--blue); color: #fff; border-color: var(--blue); }
  :root[data-theme="dark"] .uc-tab.on { background: var(--maize); color: var(--blue); border-color: var(--maize); }
  .uc-nav { display: flex; gap: .5rem; }
  .uc-btn { width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border-strong); background: var(--surface); color: var(--blue); cursor: pointer; display: grid; place-items: center; transition: all .18s; }
  :root[data-theme="dark"] .uc-btn { color: var(--text); }
  .uc-btn:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

  .uc-window { display: flex; gap: 16px; overflow-x: auto; overflow-y: hidden; scroll-snap-type: x proximity; overscroll-behavior-x: contain; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .uc-window::-webkit-scrollbar { display: none; }
  .uc-card { flex: 0 0 264px; scroll-snap-align: start; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; flex-direction: column; }
  .uc-card[data-cat] { display: flex; }

  .uc-photos { display: grid; gap: 2px; height: 150px; }
  .uc-photos.n1 { grid-template-columns: 1fr; }
  .uc-photos.n2 { grid-template-columns: 1fr 1fr; }
  .uc-photos.n3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; }
  .uc-photos.n3 .uc-photo:first-child { grid-row: 1 / 3; }
  .uc-photo { position: relative; overflow: hidden; background-color: var(--blue); }
  .uc-photo img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; cursor: zoom-in; }
  .uc-more { position: absolute; inset: 0; background: rgba(0,39,76,.62); color: #fff; font-family: var(--ff-mono); font-size: 15px; display: flex; align-items: center; justify-content: center; cursor: zoom-in; }

  .uc-body { padding: .85rem 1rem 1rem; display: flex; flex-direction: column; flex: 1; }
  .uc-date { font-family: var(--ff-mono); font-size: 11px; letter-spacing: .04em; color: var(--blue-link); background: var(--surface-soft); border: 1px solid var(--border); padding: .15rem .5rem; border-radius: 5px; align-self: flex-start; margin-bottom: .55rem; }
  .uc-msg { font-size: 13.5px; color: var(--text); line-height: 1.5; margin: 0 0 .6rem; }
  .uc-msg :global(.uc-namelink) { color: var(--blue-link); font-weight: 600; }
  .uc-link { font-family: var(--ff-mono); font-size: 12px; margin-top: auto; }

  .uc-dots { display: flex; gap: 6px; justify-content: center; margin-top: 1.1rem; }
  .uc-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--border-strong); border: 0; padding: 0; cursor: pointer; }
  .uc-dot.on { background: var(--maize); width: 20px; border-radius: 4px; }
</style>

<script is:inline>
  (function(){
    var uc = document.getElementById("updates");
    if(!uc) return;
    var win = uc.querySelector(".uc-window");
    var dots = uc.querySelector(".uc-dots");
    var active = "news";
    function cards(){ return [].slice.call(win.querySelectorAll('.uc-card[data-cat="' + active + '"]')); }
    function step(){ var c = cards()[0]; return c ? c.offsetWidth + 16 : 280; }
    function visible(){ return Math.max(1, Math.round(win.clientWidth / step())); }
    function maxIdx(){ return Math.max(0, cards().length - visible()); }
    function curIdx(){ return Math.max(0, Math.min(maxIdx(), Math.round(win.scrollLeft / step()))); }
    function renderDots(){
      var ci = curIdx(), mx = maxIdx();
      dots.innerHTML = "";
      for(var i=0;i<=mx;i++){
        var b = document.createElement("button");
        b.className = "uc-dot" + (i===ci?" on":"");
        b.setAttribute("aria-label","Go to update "+(i+1));
        (function(j){ b.onclick=function(){ win.scrollTo({ left: j*step(), behavior:"smooth" }); }; })(i);
        dots.appendChild(b);
      }
    }
    function setCat(cat){
      active = cat;
      uc.querySelectorAll(".uc-tab").forEach(function(t){ t.classList.toggle("on", t.getAttribute("data-cat")===cat); });
      [].slice.call(win.querySelectorAll(".uc-card")).forEach(function(c){ c.style.display = c.getAttribute("data-cat")===cat ? "flex" : "none"; });
      win.scrollLeft = 0;
      renderDots();
    }
    uc.querySelectorAll(".uc-tab").forEach(function(t){ t.addEventListener("click", function(){ setCat(t.getAttribute("data-cat")); }); });
    uc.querySelectorAll(".uc-btn").forEach(function(b){
      b.addEventListener("click", function(){ win.scrollBy({ left: parseInt(b.getAttribute("data-dir"),10)*step(), behavior:"smooth" }); });
    });
    var raf=null;
    win.addEventListener("scroll", function(){ if(raf) return; raf = requestAnimationFrame(function(){ raf=null; renderDots(); }); }, {passive:true});
    window.addEventListener("resize", renderDots);
    win.addEventListener("wheel", function(e){
      var maxScroll = win.scrollWidth - win.clientWidth;
      if(maxScroll <= 1) return;
      var horiz = Math.abs(e.deltaX) > Math.abs(e.deltaY);
      var delta = horiz ? e.deltaX : e.deltaY;
      if(!delta) return;
      var atStart = win.scrollLeft <= 0, atEnd = win.scrollLeft >= maxScroll - 1;
      if(!horiz && ((delta < 0 && atStart) || (delta > 0 && atEnd))) return;
      e.preventDefault();
      win.scrollLeft += delta;
    }, {passive:false});
    setCat("news");
  })();
</script>
