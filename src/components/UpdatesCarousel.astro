---
import all from "../data/updates.json";
const updates = all.slice(0, 12);
---
<div class="uc" id="updates">
  <div class="uc-head">
    <div>
      <span class="eyebrow">Recent updates</span>
      <h2 class="h-sec">News from the lab</h2>
    </div>
    <div class="uc-nav">
      <button class="uc-btn" onclick="ucMove(-1)" aria-label="Previous updates">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
      <button class="uc-btn" onclick="ucMove(1)" aria-label="Next updates">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>

  <div class="uc-window">
    <div class="uc-track" id="uc-track">
      {updates.map((u) => (
        <article class="uc-card">
          {u.images && u.images.length > 0 && (
            <div class={"uc-photos n" + Math.min(u.images.length, 3)}>
              {u.images.slice(0, 3).map((img, i) => (
                <div class="uc-photo">
                  <img src={img} data-gallery={JSON.stringify(u.images)} data-index={i} alt="" loading="lazy" onerror="this.closest('.uc-photo').style.display='none'" />
                  {i === 2 && u.images.length > 3 && <span class="uc-more" data-gallery={JSON.stringify(u.images)} data-index={i}>+{u.images.length - 3}</span>}
                </div>
              ))}
            </div>
          )}
          <div class="uc-body">
            <span class="uc-date">{u.date}</span>
            <p class="uc-msg">{u.message}</p>
            {u.link && <a class="uc-link" href={u.link} target="_blank" rel="noopener">View post →</a>}
          </div>
        </article>
      ))}
    </div>
  </div>
  <div class="uc-dots" id="uc-dots"></div>
</div>

<style>
  .uc { margin-top: .5rem; }
  .uc-head { display: flex; justify-content: space-between; align-items: flex-end; gap: 1rem; margin-bottom: 1.2rem; }
  .uc-nav { display: flex; gap: .5rem; }
  .uc-btn { width: 40px; height: 40px; border-radius: 50%; border: 1px solid var(--border-strong); background: var(--surface); color: var(--blue); cursor: pointer; display: grid; place-items: center; transition: all .18s; }
  :root[data-theme="dark"] .uc-btn { color: var(--text); }
  .uc-btn:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

  .uc-window { overflow: hidden; }
  .uc-track { display: flex; gap: 16px; transition: transform .35s cubic-bezier(.2,.7,.3,1); }
  .uc-card { flex: 0 0 264px; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; display: flex; flex-direction: column; }

  .uc-photos { display: grid; gap: 2px; height: 150px; }
  .uc-photos.n1 { grid-template-columns: 1fr; }
  .uc-photos.n2 { grid-template-columns: 1fr 1fr; }
  .uc-photos.n3 { grid-template-columns: 2fr 1fr; grid-template-rows: 1fr 1fr; }
  .uc-photos.n3 .uc-photo:first-child { grid-row: 1 / 3; }
  .uc-photo { position: relative; overflow: hidden; background-color: var(--blue); }
  .uc-photo img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; cursor: zoom-in; }
  .uc-more { position: absolute; inset: 0; background: rgba(0,39,76,.62); color: #fff; font-family: var(--ff-mono); font-size: 15px; display: flex; align-items: center; justify-content: center; cursor: zoom-in; }

  .uc-body { padding: .85rem 1rem 1rem; display: flex; flex-direction: column; flex: 1; }
  .uc-date { font-family: var(--ff-mono); font-size: 11px; letter-spacing: .04em; color: var(--blue-link); background: var(--surface-soft); border: 1px solid var(--border); padding: .15rem .5rem; border-radius: 5px; align-self: flex-start; margin-bottom: .55rem; }
  .uc-msg { font-size: 13.5px; color: var(--text); line-height: 1.5; margin: 0 0 .6rem; }
  .uc-link { font-family: var(--ff-mono); font-size: 12px; margin-top: auto; }

  .uc-dots { display: flex; gap: 6px; justify-content: center; margin-top: 1.1rem; }
  .uc-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--border-strong); border: 0; padding: 0; cursor: pointer; }
  .uc-dot.on { background: var(--maize); width: 20px; border-radius: 4px; }
</style>

<script is:inline>
  (function(){
    var track = document.getElementById("uc-track");
    if(!track) return;
    var cards = track.children.length;
    var idx = 0;
    function step(){ var c = track.querySelector(".uc-card"); return c ? c.offsetWidth + 16 : 280; }
    function visible(){ return Math.max(1, Math.floor((track.parentElement.clientWidth + 16) / step())); }
    function maxIdx(){ return Math.max(0, cards - visible()); }
    function render(){
      idx = Math.min(idx, maxIdx());
      track.style.transform = "translateX(" + (-idx * step()) + "px)";
      var dots = document.getElementById("uc-dots");
      dots.innerHTML = "";
      for(var i=0;i<=maxIdx();i++){
        var b = document.createElement("button");
        b.className = "uc-dot" + (i===idx?" on":"");
        b.setAttribute("aria-label","Go to update "+(i+1));
        (function(j){ b.onclick=function(){ idx=j; render(); }; })(i);
        dots.appendChild(b);
      }
    }
    window.ucMove = function(d){ idx += d; if(idx<0) idx=0; if(idx>maxIdx()) idx=maxIdx(); render(); };
    window.addEventListener("resize", render);

    // touch swipe (finger-following drag with snap)
    var win = track.parentElement;
    var startX=0, startY=0, base=0, dragging=false, horiz=false;
    win.addEventListener("touchstart", function(e){
      if(e.touches.length!==1) return;
      startX=e.touches[0].clientX; startY=e.touches[0].clientY;
      base=-idx*step(); dragging=true; horiz=false;
      track.style.transition="none";
    }, {passive:true});
    win.addEventListener("touchmove", function(e){
      if(!dragging) return;
      var dx=e.touches[0].clientX-startX, dy=e.touches[0].clientY-startY;
      if(!horiz && Math.abs(dx)>Math.abs(dy)+4) horiz=true;
      if(horiz){ e.preventDefault(); track.style.transform="translateX("+(base+dx)+"px)"; }
    }, {passive:false});
    function endDrag(e){
      if(!dragging) return; dragging=false;
      track.style.transition="";
      var dx=(e.changedTouches&&e.changedTouches[0]?e.changedTouches[0].clientX:startX)-startX;
      var th=Math.max(40, step()*0.18);
      if(dx<=-th) idx=Math.min(idx+1, maxIdx());
      else if(dx>=th) idx=Math.max(idx-1, 0);
      render();
    }
    win.addEventListener("touchend", endDrag);
    win.addEventListener("touchcancel", endDrag);

    // trackpad / mouse-wheel horizontal gesture (follow + snap)
    var wheeling=false, accum=0, wheelTimer=null;
    win.addEventListener("wheel", function(e){
      if(Math.abs(e.deltaX) <= Math.abs(e.deltaY)) return; // let vertical page scroll pass
      if(maxIdx()<=0) return; // nothing to scroll
      e.preventDefault();
      if(!wheeling){ wheeling=true; accum=-idx*step(); track.style.transition="none"; }
      accum -= e.deltaX;
      var min=-maxIdx()*step();
      if(accum>0) accum=0; if(accum<min) accum=min;
      track.style.transform="translateX("+accum+"px)";
      clearTimeout(wheelTimer);
      wheelTimer=setTimeout(function(){
        wheeling=false;
        track.style.transition="";
        idx=Math.round(-accum/step());
        if(idx<0) idx=0; if(idx>maxIdx()) idx=maxIdx();
        render();
      }, 120);
    }, {passive:false});

    render();
  })();
</script>
