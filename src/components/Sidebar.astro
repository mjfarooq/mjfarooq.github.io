---
import site from "../data/site.json";
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const nav = [
  { href: "/", label: "Home" },
  { href: "/news", label: "News" },
  { href: "/research", label: "Research" },
  { href: "/publications", label: "Publications" },
  { href: "/teaching", label: "Teaching" },
  { href: "/group", label: "Group" },
  { href: "/about", label: "About" },
  { href: "/ask", label: "Ask AI" },
];
const isActive = (h) => h === "/" ? path === "/" : path.startsWith(h);
---
<div class="nav-scrim" onclick="toggleSidebar()" aria-hidden="true"></div>
<button class="nav-toggle" aria-label="Menu" onclick="toggleSidebar()">
  <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18" stroke-linecap="round"/></svg>
</button>
<aside class="sidebar">
  <div class="sb-inner">
    <div class="sb-top">
      <img class="avatar" src="/images/avatar.jpg" alt="Junaid Farooq" />
      <div class="sb-name">{site.name}</div>
      <div class="sb-role">{site.role}</div>
      <div class="sb-dept">{site.department}</div>
      <a class="sb-inst" href={site.institutionUrl} target="_blank" rel="noopener">{site.institution}</a>
    </div>

    <nav class="sb-nav" aria-label="Primary">
      {nav.map((n) => (
        <a href={n.href} class={isActive(n.href) ? "active" : ""}>{n.label}</a>
      ))}
    </nav>

    <div class="sb-links">
      {site.social.map((s) => (
        <a href={s.url} target="_blank" rel="noopener" title={s.label} aria-label={s.label}>{s.label}</a>
      ))}
    </div>

    <div class="sb-actions">
      <a class="btn btn-maize sb-cv" href={site.cvUrl} target="_blank" rel="noopener">Curriculum Vitae</a>
      <button class="theme-btn" onclick="toggleTheme()" aria-label="Toggle theme" title="Toggle light/dark">
        <svg class="ic-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4.2"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19" stroke-linecap="round"/></svg>
        <svg class="ic-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 14.5A8 8 0 1 1 9.5 4 6.5 6.5 0 0 0 20 14.5Z" stroke-linejoin="round"/></svg>
      </button>
    </div>
  </div>
</aside>

<style>
  .sidebar { position: fixed; top: 0; left: 0; width: var(--sb-w); height: 100vh; background: var(--sidebar);
    border-right: 3px solid var(--maize); overflow-y: auto; z-index: 40; }
  .sb-inner { padding: 2.2rem 1.6rem; display: flex; flex-direction: column; min-height: 100%; }
  .sb-top { text-align: center; }
  .avatar { width: 128px; height: 128px; border-radius: 50%; object-fit: cover; border: 3px solid var(--maize); margin-bottom: 1rem; }
  .sb-name { font-family: var(--ff-serif); font-size: 1.5rem; font-weight: 600; color: #fff; line-height: 1.1; }
  .sb-role { color: var(--maize); font-size: .92rem; margin-top: .4rem; font-weight: 500; }
  .sb-dept { color: #c2d0e2; font-size: .82rem; margin-top: .1rem; }
  .sb-inst { color: #9fb3cc; font-size: .8rem; display: block; margin-top: .35rem; }
  .sb-inst:hover { color: var(--maize); }

  .sb-nav { display: flex; flex-direction: column; margin: 1.8rem 0 1.2rem; border-top: 1px solid rgba(255,255,255,.12); }
  .sb-nav a { color: #d4dded; font-family: var(--ff-sans); font-size: .96rem; font-weight: 500; padding: .7rem .4rem; border-bottom: 1px solid rgba(255,255,255,.08); display: flex; align-items: center; gap: .6rem; transition: color .15s, padding-left .15s; }
  .sb-nav a:hover { color: #fff; text-decoration: none; padding-left: .8rem; }
  .sb-nav a.active { color: var(--maize); }
  .sb-nav a.active::before { content: ""; width: 7px; height: 7px; background: var(--maize); border-radius: 50%; }

  .sb-links { display: flex; flex-wrap: wrap; gap: .4rem .9rem; margin-bottom: 1.4rem; }
  .sb-links a { color: #9fb3cc; font-family: var(--ff-mono); font-size: .72rem; letter-spacing: .02em; }
  .sb-links a:hover { color: var(--maize); text-decoration: none; }

  .sb-actions { margin-top: auto; display: flex; gap: .5rem; align-items: center; }
  .sb-cv { flex: 1; justify-content: center; }
  .theme-btn { width: 38px; height: 38px; flex: 0 0 38px; border-radius: 8px; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.18); color: #d4dded; cursor: pointer; display: grid; place-items: center; }
  .theme-btn:hover { color: var(--maize); border-color: var(--maize); }
  .ic-moon { display: none; }
  :root[data-theme="dark"] .ic-sun { display: none; }
  :root[data-theme="dark"] .ic-moon { display: block; }

  .nav-toggle { display: none; position: fixed; top: 14px; left: 14px; z-index: 60; width: 44px; height: 44px; border-radius: 9px; background: var(--blue); color: #fff; border: 0; cursor: pointer; align-items: center; justify-content: center; box-shadow: 0 4px 14px rgba(0,39,76,.3); }
  .nav-scrim { display: none; }

  @media (max-width: 880px) {
    .sidebar { transform: translateX(-100%); transition: transform .28s ease; box-shadow: 0 0 50px rgba(0,0,0,.4); }
    body.nav-open .sidebar { transform: none; }
    .nav-toggle { display: flex; }
    body.nav-open .nav-scrim { display: block; position: fixed; inset: 0; background: rgba(8,18,34,.45); z-index: 39; }
  }
</style>
