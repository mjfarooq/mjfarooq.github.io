---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import site from "../data/site.json";
const { title, description, image } = Astro.props;
const pageTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.role}, ${site.institution}`;
const desc = description || site.bioShort;
const canonPath = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";
const canonical = new URL(canonPath, Astro.site).href;
const ogImage = new URL(image || "/images/avatar.jpg", Astro.site).href;
const sameAs = (site.social || []).filter((s) => s.url && !s.url.startsWith("mailto:")).map((s) => s.url);
const twitter = (site.social || []).find((s) => s.key === "twitter");
const twitterHandle = twitter ? "@" + twitter.url.split("/").pop() : undefined;
const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: site.name,
  jobTitle: site.role,
  affiliation: { "@type": "CollegeOrUniversity", name: site.institution, url: site.institutionUrl },
  worksFor: { "@type": "CollegeOrUniversity", name: site.institution, url: site.institutionUrl },
  url: "https://mjfarooq.github.io/",
  image: ogImage,
  email: site.email,
  description: site.bioShort,
  knowsAbout: site.interests || undefined,
  sameAs,
};
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content={site.name} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={desc} />
  <meta property="og:type" content="profile" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content={site.name} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={ogImage} />
  {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}
  <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  <link rel="icon" href="/favicon.ico?v=3" sizes="any" />
  <link rel="icon" href="/favicon.svg?v=3" type="image/svg+xml" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png?v=3" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png?v=3" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=3" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    (function(){ try { var t = localStorage.getItem("theme"); if(t) document.documentElement.setAttribute("data-theme", t); } catch(e){} })();
  </script>
</head>
<body>
  <div class="layout">
    <Sidebar />
    <div class="main">
      <div class="mobile-id">
        <img class="mid-avatar" src="/images/avatar.jpg" alt={site.name} />
        <div>
          <div class="mid-name">{site.name}</div>
          <div class="mid-role">{site.role}</div>
          <div class="mid-dept">{site.department}</div>
        </div>
      </div>
      <slot />
      <footer class="site-foot">
        <div class="container foot-inner">
          <span>&copy; {new Date().getFullYear()} {site.name}</span>
          <span class="foot-meta">{site.role}, {site.institution}</span>
        </div>
      </footer>
    </div>
  </div>
  {!Astro.url.pathname.startsWith("/ask") && (
    <a class="ask-fab" href="/ask" aria-label="Ask AI about this research" title="Ask AI">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 2l1.6 4.4L18 8l-4.4 1.6L12 14l-1.6-4.4L6 8l4.4-1.6L12 2z" stroke-linejoin="round" stroke-linecap="round" fill="currentColor" fill-opacity=".15"/>
        <path d="M5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16z" stroke-linejoin="round" stroke-linecap="round" fill="currentColor" fill-opacity=".15"/>
      </svg>
      <span class="ask-fab-label">Ask AI</span>
    </a>
  )}
  <div id="lightbox" class="lightbox" aria-hidden="true">
    <button class="lb-close" aria-label="Close">&times;</button>
    <button class="lb-prev" aria-label="Previous photo">&#8249;</button>
    <img class="lb-img" alt="" />
    <button class="lb-next" aria-label="Next photo">&#8250;</button>
    <div class="lb-counter"></div>
  </div>
  <style>
    .site-foot { border-top: 1px solid var(--border); margin-top: 2.5rem; }
    .ask-fab { position: fixed; top: 18px; right: 22px; z-index: 80; display: inline-flex; align-items: center; gap: .55rem; padding: .55rem 1rem .55rem .8rem; background: linear-gradient(135deg, var(--blue) 0%, #1e4a82 100%); color: #fff; border-radius: 999px; box-shadow: 0 6px 22px rgba(0,39,76,.35), 0 2px 6px rgba(0,0,0,.18); border: 2px solid var(--maize); font-family: var(--ff-sans); font-size: 13px; font-weight: 600; letter-spacing: .01em; transition: transform .18s, box-shadow .18s, background .18s; text-decoration: none; }
    .ask-fab:hover { transform: translateY(-1px); box-shadow: 0 10px 28px rgba(0,39,76,.45), 0 3px 8px rgba(0,0,0,.22); color: #fff; text-decoration: none; }
    .ask-fab svg { color: var(--maize); flex: 0 0 auto; }
    .ask-fab-label { white-space: nowrap; }
    @media (max-width: 880px) {
      .ask-fab { top: 14px; right: 64px; padding: .5rem .85rem .5rem .65rem; font-size: 12px; }
    }
    @media (max-width: 560px) {
      .ask-fab { padding: .45rem; }
      .ask-fab-label { display: none; }
    }
    .foot-inner { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; padding-top: 1.6rem; padding-bottom: 2rem; font-family: var(--ff-mono); font-size: 12px; color: var(--text-mute); }
    .lightbox { display: none; position: fixed; inset: 0; z-index: 200; background: rgba(8,18,34,.9); align-items: center; justify-content: center; padding: 24px; cursor: zoom-out; }
    .lightbox.open { display: flex; }
    .lb-img { max-width: 88vw; max-height: 86vh; border-radius: 8px; box-shadow: 0 24px 70px rgba(0,0,0,.55); }
    .lb-close { position: fixed; top: 16px; right: 20px; width: 46px; height: 46px; border: 0; background: rgba(255,255,255,.14); color: #fff; font-size: 28px; line-height: 1; border-radius: 50%; cursor: pointer; }
    .lb-close:hover { background: rgba(255,255,255,.26); }
    .lb-prev, .lb-next { position: fixed; top: 50%; transform: translateY(-50%); width: 50px; height: 50px; border: 0; background: rgba(255,255,255,.14); color: #fff; font-size: 30px; line-height: 1; border-radius: 50%; cursor: pointer; display: none; }
    .lb-prev { left: 18px; } .lb-next { right: 18px; }
    .lb-prev:hover, .lb-next:hover { background: rgba(255,255,255,.28); }
    .lb-counter { position: fixed; bottom: 22px; left: 0; right: 0; text-align: center; color: #e7ecf2; font-family: var(--ff-mono); font-size: 13px; display: none; }
    @media (max-width: 560px) { .lb-prev { left: 8px; } .lb-next { right: 8px; } }
  </style>
  <script is:inline>
    (function(){
      var io = new IntersectionObserver(function(es){ es.forEach(function(e){ if(e.isIntersecting){ e.target.classList.add("in"); io.unobserve(e.target);} }); }, { threshold: 0.1 });
      function bind(){ document.querySelectorAll(".reveal:not(.in)").forEach(function(el){ io.observe(el); }); }
      document.addEventListener("DOMContentLoaded", bind); bind();
    })();
    function toggleTheme(){ var c=document.documentElement.getAttribute("data-theme"); var n=c==="dark"?"":"dark"; if(n) document.documentElement.setAttribute("data-theme",n); else document.documentElement.removeAttribute("data-theme"); try{ localStorage.setItem("theme",n);}catch(e){} }
    function toggleSidebar(){ document.body.classList.toggle("nav-open"); }
    window.toggleTheme=toggleTheme; window.toggleSidebar=toggleSidebar;
    (function(){
      var lb=document.getElementById("lightbox"); if(!lb) return;
      var img=lb.querySelector(".lb-img"), counter=lb.querySelector(".lb-counter");
      var items=[], idx=0;
      function show(){ img.src=items[idx]||""; var multi=items.length>1; counter.textContent=(idx+1)+" / "+items.length; counter.style.display=multi?"":"none"; lb.querySelector(".lb-prev").style.display=multi?"":"none"; lb.querySelector(".lb-next").style.display=multi?"":"none"; }
      function open(list, i){ items=list; idx=i||0; lb.classList.add("open"); lb.setAttribute("aria-hidden","false"); document.body.style.overflow="hidden"; show(); }
      function close(){ lb.classList.remove("open"); lb.setAttribute("aria-hidden","true"); img.src=""; document.body.style.overflow=""; }
      function step(d){ if(!items.length) return; idx=(idx+d+items.length)%items.length; show(); }
      function parse(el){ try { return JSON.parse(el.getAttribute("data-gallery")); } catch(e){ var z=el.getAttribute("data-zoom"); return z?[z]:[]; } }
      document.addEventListener("click",function(e){
        var trig=e.target.closest("[data-gallery],[data-zoom]");
        if(trig && !e.target.closest(".lightbox")){ e.preventDefault(); open(parse(trig), parseInt(trig.getAttribute("data-index")||"0",10)); return; }
        if(e.target.closest(".lb-prev")){ step(-1); return; }
        if(e.target.closest(".lb-next")){ step(1); return; }
        if(e.target.closest(".lightbox")){ close(); }
      });
      document.addEventListener("keydown",function(e){
        if(!lb.classList.contains("open")) return;
        if(e.key==="Escape") close();
        else if(e.key==="ArrowLeft") step(-1);
        else if(e.key==="ArrowRight") step(1);
      });
    })();
  </script>
</body>
</html>
