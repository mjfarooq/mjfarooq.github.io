---
import Base from "../../layouts/Base.astro";
import site from "../../data/site.json";
const initials = (n) => n.split(" ").map(w=>w[0]).join("").slice(0,2).toUpperCase();
---
<Base title="Group" description="The Cyber Resilient Networks (CyReN) Lab.">
  <div class="container">
    <section class="section">
      <span class="eyebrow">Group</span>
      <h1 class="h-page">{site.lab.fullName}</h1>
      <p class="lead">{site.group.blurb}</p>
      <a class="btn btn-primary" href={site.lab.url} target="_blank" rel="noopener">Visit the {site.lab.name} Lab site →</a>
    </section>

    <section class="section reveal">
      <h2 class="h-sec">Current members</h2>
      <div class="grid-2 members">
        {site.group.members.map((m) => (
          <article class="card member">
            <div class="m-av">
              {m.photo && <img src={m.photo} alt={m.name} loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='grid'" />}
              <span class="m-ini" style={m.photo ? "display:none" : ""}>{initials(m.name)}</span>
            </div>
            <div>
              {m.profile
                ? <a class="m-name" href={m.profile} target="_blank" rel="noopener">{m.name}</a>
                : <div class="m-name">{m.name}</div>}
              <div class="m-role">{m.role}</div>
              {m.focus && <div class="m-focus">{m.focus}</div>}
              {m.profile && <a class="m-link" href={m.profile} target="_blank" rel="noopener">Profile →</a>}
            </div>
          </article>
        ))}
      </div>
    </section>

    {site.group.alumni && site.group.alumni.length > 0 && (
      <section class="section reveal">
        <h2 class="h-sec">Alumni</h2>
        <div class="grid-2 alumni-grid">
          {site.group.alumni.map((a) => (
            <div class="alum">
              <div class="alum-av">{initials(a.name)}</div>
              <div>
                {a.linkedin
                  ? <a class="alum-name" href={a.linkedin} target="_blank" rel="noopener">{a.name}</a>
                  : <span class="alum-name">{a.name}</span>}
                {a.note && <div class="alum-note">{a.note}</div>}
                {a.year && <div class="alum-year">{a.year}</div>}
              </div>
            </div>
          ))}
        </div>
      </section>
    )}

    <section class="section reveal join">
      <h2 class="h-sec">Join the lab</h2>
      <p>I am looking for motivated Ph.D. and master's students interested in NextG networks, cyber resilience, and AI-driven network management. Prospective students should email me with a CV and a short note on research interests.</p>
      <a class="btn btn-maize" href={"mailto:" + site.email}>Email {site.email}</a>
    </section>
  </div>
</Base>

<style>
  .members { margin-top: 1.3rem; }
  .member { display: flex; gap: 1.2rem; align-items: center; }
  .m-av { width: 112px; height: 132px; flex: 0 0 112px; border-radius: 12px; overflow: hidden; background: var(--blue); border: 1px solid var(--border); }
  .m-av img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .m-ini { width: 100%; height: 100%; display: grid; place-items: center; color: var(--maize); font-family: var(--ff-mono); font-size: 22px; }
  .m-name { display: inline-block; font-weight: 600; font-family: var(--ff-serif); font-size: 1.1rem; color: var(--blue); }
  a.m-name:hover { color: var(--blue-link); }
  :root[data-theme="dark"] .m-name { color: var(--text); }
  .m-role { font-size: .85rem; color: var(--blue-link); }
  .m-focus { font-size: .85rem; color: var(--text-mute); }
  .m-link { display: inline-block; margin-top: .4rem; font-family: var(--ff-mono); font-size: 12px; color: var(--blue-link); }
  .alumni-grid { margin-top: 1.3rem; }
  .alum { display: flex; gap: 1rem; align-items: center; }
  .alum-av { width: 54px; height: 54px; flex: 0 0 54px; border-radius: 50%; background: var(--blue); color: var(--maize); font-family: var(--ff-mono); font-size: 14px; display: grid; place-items: center; }
  .alum-name { font-family: var(--ff-serif); font-weight: 600; font-size: 1.02rem; color: var(--blue); }
  :root[data-theme="dark"] .alum-name { color: var(--text); }
  a.alum-name:hover { color: var(--blue-link); }
  .alum-note { font-size: .84rem; color: var(--text-mute); }
  .alum-year { font-family: var(--ff-mono); font-size: .78rem; color: var(--blue-link); }
  .join { border-top: 3px solid var(--maize); margin-top: 2rem; padding-top: 1.6rem; }
</style>
