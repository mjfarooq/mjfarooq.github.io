---
import Base from "../layouts/Base.astro";
---
<Base title="Not found">
  <section class="section" style="text-align:center; padding-top:18vh;">
    <div class="wrap">
      <span class="kicker" style="justify-content:center;">// error 404</span>
      <h1 class="h-display" style="font-size:clamp(3rem,10vw,6rem);">404</h1>
      <p class="lead" style="margin:0 auto 2rem;">This page drifted out of range. Let's get you back to the network.</p>
      <a class="btn btn-primary" href="/">Return home</a>
    </div>
  </section>
</Base>
