---
import Base from "../layouts/Base.astro";
import UpdatesCarousel from "../components/UpdatesCarousel.astro";
import site from "../data/site.json";
import areaIcons from "../data/areaIcons.js";
import pubs from "../data/publications.json";
const recent = pubs
  .filter(p => p.type !== "Thesis")
  .map(p => ({ ...p, link: p.url || (p.links && p.links[0] && p.links[0].url) || "" }))
  .filter(p => p.link)
  .slice(0, 5);
const counts = {
  total: pubs.filter(p=>p.type!=="Thesis").length,
  journals: pubs.filter(p=>p.type==="Journal").length,
  conferences: pubs.filter(p=>p.type==="Conference").length,
  books: pubs.filter(p=>p.type==="Book"||p.type==="Book Chapter").length,
};
---
<Base>
  <div class="container">
    <section class="section">
      <span class="eyebrow">Welcome</span>
      <h1 class="h-page">Secure, resilient, and intelligent networks.</h1>
      <p class="lead intro">{site.bioShort}</p>
      <div class="interests">
        {site.interests.map((i) => <span class="tag">{i}</span>)}
      </div>
      <div class="cta">
        <a class="btn btn-maize lab-cta" href={site.lab.url} target="_blank" rel="noopener">Visit the {site.lab.name} Lab →</a>
        <a class="btn btn-primary" href="/publications">Publications</a>
        <a class="btn" href="/research">Research</a>
        <a class="btn" href={"mailto:" + site.email}>Get in touch</a>
      </div>
      <div class="stats">
        <a class="stat" href="/publications"><b>{counts.total}+</b><span>Publications</span></a>
        <a class="stat" href="/publications?type=Journal"><b>{counts.journals}</b><span>Journal articles</span></a>
        <a class="stat" href="/publications?type=Conference"><b>{counts.conferences}</b><span>Conference papers</span></a>
        <a class="stat" href="/publications?type=Book"><b>{counts.books}</b><span>Books & chapters</span></a>
      </div>
    </section>

    <section class="section reveal">
      <UpdatesCarousel />
      <a class="btn link-more" href="/news">All news →</a>
    </section>

    <section class="section reveal">
      <span class="eyebrow">Research</span>
      <h2 class="h-sec">Focus areas</h2>
      <p class="lead">My group builds networks that stay secure and keep working under stress, attack, and uncertainty, from the wireless edge to autonomous systems.</p>
      <div class="grid-2 areas">
        {site.researchAreas.map((a) => (
          <article class="card">
            {areaIcons[a.title] && <div class="area-icon" set:html={areaIcons[a.title]}></div>}
            <h3 class="area-title">{a.title}</h3>
            <p class="area-blurb">{a.blurb}</p>
            <div class="area-tags">{a.tags.map((t) => <span class="tag">{t}</span>)}</div>
          </article>
        ))}
      </div>
      <a class="btn link-more" href="/research">Explore research and projects →</a>
    </section>

    <section class="section reveal">
      <span class="eyebrow">Publications</span>
      <h2 class="h-sec">Selected recent work</h2>
      <ul class="pub-mini">
        {recent.map((p) => (
          <li>
            <span class="pm-year">{p.year}</span>
            <div>
              {p.link ? <a class="pm-title" href={p.link} target="_blank" rel="noopener">{p.title}</a> : <span class="pm-title">{p.title}</span>}
              <div class="pm-venue">{p.venue}</div>
            </div>
          </li>
        ))}
      </ul>
      <a class="btn link-more" href="/publications">View all publications →</a>
    </section>

    <section class="section reveal contact-band">
      <h2 class="h-sec">Work with me</h2>
      <p>Prospective students and collaborators interested in NextG networks, cyber resilience, and autonomous systems are welcome to reach out.</p>
      <div class="cta">
        <a class="btn btn-maize" href={"mailto:" + site.email}>{site.email}</a>
        <a class="btn" href={site.lab.url} target="_blank" rel="noopener">Visit the {site.lab.name} Lab →</a>
      </div>
      <div class="contact-details">
        {site.office && <div><span class="cd-label">Office</span>{site.office}</div>}
        {site.phone && <div><span class="cd-label">Phone</span><a href={"tel:" + site.phone.replace(/[^+0-9]/g, "")}>{site.phone}</a></div>}
      </div>
    </section>
  </div>
</Base>

<style>
  .intro { max-width: 64ch; }
  .interests { display: flex; flex-wrap: wrap; gap: .45rem; margin: 1.3rem 0; }
  .cta { display: flex; flex-wrap: wrap; gap: .6rem; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: .8rem; margin-top: 2rem; border-top: 1px solid var(--border); padding-top: 1.6rem; }
  .stat { display: block; padding: .4rem .2rem; border-radius: 8px; transition: background .15s; }
  a.stat:hover { text-decoration: none; background: var(--bg-soft); }
  a.stat:hover b { color: var(--blue-link); }
  .stat b { font-family: var(--ff-serif); font-size: 1.7rem; color: var(--blue); display: block; line-height: 1; }
  :root[data-theme="dark"] .stat b { color: var(--maize); }
  .stat span { font-size: .8rem; color: var(--text-mute); }
  .areas { margin-top: 1.4rem; }
  .area-icon { width: 48px; height: 48px; border-radius: 11px; background: var(--bg-soft); border: 1px solid var(--border); color: var(--blue); display: grid; place-items: center; margin-bottom: .9rem; }
  .area-icon :global(svg) { width: 26px; height: 26px; }
  :root[data-theme="dark"] .area-icon { color: var(--maize); background: var(--surface); }
  .area-title { font-size: 1.2rem; margin-bottom: .5rem; }
  .area-blurb { font-size: .92rem; margin-bottom: .8rem; }
  .area-tags { display: flex; flex-wrap: wrap; gap: .35rem; }
  .link-more { margin-top: 1.4rem; }
  .pub-mini { list-style: none; padding: 0; margin: 1.2rem 0 0; }
  .pub-mini li { display: grid; grid-template-columns: 54px 1fr; gap: 1rem; padding: 1rem 0; border-top: 1px solid var(--border); }
  .pm-year { font-family: var(--ff-mono); font-size: 13px; color: var(--blue-link); }
  .pm-title { font-weight: 500; color: var(--text); font-size: 1rem; line-height: 1.35; }
  a.pm-title:hover { color: var(--blue-link); }
  .pm-venue { font-size: .85rem; color: var(--text-mute); font-style: italic; margin-top: .15rem; }
  .contact-band { border-top: 3px solid var(--maize); margin-top: 2.5rem; padding-top: 1.8rem; }
  .contact-details { margin-top: 1.4rem; display: flex; flex-direction: column; gap: .4rem; font-size: .92rem; color: var(--text-soft); }
  .cd-label { font-family: var(--ff-mono); font-size: 11px; letter-spacing: .08em; text-transform: uppercase; color: var(--text-mute); margin-right: .7rem; }
  @media (max-width: 560px) { .stats { grid-template-columns: repeat(2, 1fr); } }
</style>
